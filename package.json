{
  "name": "agenticloop",
  "version": "0.3.0",
  "description": "Loop engineering for AI coding agents – shaping the whole run, not one prompt: a Markdown-first overlay of task records, role boundaries, verification evidence, and review gates that holds across multi-hour work",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.8.2",
  "bin": {
    "agenticloop": "./bin/agenticloop.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bartoszarendt/agenticloop.git"
  },
  "homepage": "https://github.com/bartoszarendt/agenticloop#readme",
  "bugs": {
    "url": "https://github.com/bartoszarendt/agenticloop/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "agentic",
    "loop-engineering",
    "workflow",
    "skills",
    "markdown",
    "opencode",
    "codex",
    "claude-code",
    "copilot",
    "cursor"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node --test \"test/**/*.test.js\"",
    "test:dot": "node --test --test-reporter=dot \"test/**/*.test.js\"",
    "test:fast": "node scripts/run-tests.js fast",
    "test:e2e": "node scripts/run-tests.js e2e",
    "test:groups": "node scripts/run-tests.js check",
    "test:profile": "node scripts/profile-tests.js",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "files": [
    "bin/",
    "src/",
    ".claude-plugin/",
    "AGENTIC_LOOP.md",
    "agents/",
    "backends/",
    "skills/",
    "commands/",
    "memory/",
    "config.json",
    "agenticloop.template.json",
    "manifest.json",
    "docs/getting-started.md",
    "docs/downstream-adoption.md",
    "docs/host-adapters.md",
    "docs/opencode-setup.md",
    "docs/codex-setup.md",
    "docs/claude-code-setup.md",
    "docs/copilot-setup.md",
    "docs/cursor-setup.md",
    "docs/skill-anatomy.md",
    "docs/workflow-examples.md",
    "docs/registry-horizon.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^20.19.43",
    "typescript": "^6.0.3"
  }
}
